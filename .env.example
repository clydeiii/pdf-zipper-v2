# Redis Configuration
# Host where Redis server is running
REDIS_HOST=localhost

# Redis port (default: 6379)
REDIS_PORT=6379

# Server Configuration
# Port for the Express HTTP server
PORT=3002

# Environment
# development | production | test
NODE_ENV=development

# Ollama Configuration
OLLAMA_HOST=http://localhost:11434
# Vision model for quality scoring (default: gemma4:e4b)
OLLAMA_MODEL=gemma4:e4b
# Model for transcript formatting + metadata enrichment (default: gemma4:latest, 8B Q4_K_M)
# TRANSCRIPT_FORMAT_MODEL=gemma4:latest

# Optional llama.cpp OpenAI-compatible server for text-only round-robin/failover.
# Used for metadata enrichment (extractMetadata + translateToEnglish). When set,
# requests try OLLAMA_HOST first and fall through to LLAMACPP_HOST on error.
# Vision (quality scoring) and transcript formatting still go to Ollama only.
# LLAMACPP_HOST=http://10.0.0.81:8080
# LLAMACPP_API_KEY=
# LLAMACPP_MODEL=gemma4

# Feed ingestion
# MATTER_FEED_URL=
# KARAKEEP_FEED_URL=
# FEED_POLL_INTERVAL_MINUTES=5

# Karakeep retention cleanup
# KARAKEEP_API_BASE=http://karakeep-web-1:3000
# KARAKEEP_API_TOKEN=
# KARAKEEP_RETENTION_DAYS=90

# Local retention cleanup
# RETENTION_DAYS=90

# Data directory for media storage (default: ./data)
DATA_DIR=./data

# Cookies file for authenticated access (paywalls, subscriptions)
# Netscape cookies.txt format - export from browser extensions
# COOKIES_FILE=./data/cookies.txt

# Optional dedicated cookies file for yt-dlp Google auth (age-gated /
# member-only videos). Only consulted as a fallback when an anonymous
# metadata fetch fails. Keep separate from COOKIES_FILE so a personal
# Google login in the paywall cookies doesn't trigger YouTube bot-detection.
# YT_DLP_COOKIES_FILE=./data/yt-cookies.txt

# Nitter mirror for Twitter/X captures
# NITTER_HOST=http://localhost:8080

# Playwright/conversion tuning
# CONCURRENCY=1
# NAV_TIMEOUT_MS=60000
# PDF_TIMEOUT_MS=90000
# DIRECT_DOWNLOAD_TIMEOUT_MS=120000
# MAX_DIRECT_PDF_MB=100

# Podcast/video media tuning
# WHISPER_HOST=http://10.0.0.81:9002
# WHISPER_HOST_FALLBACK=
# MEDIA_DOWNLOAD_TIMEOUT_MS=300000
# PODCAST_DOWNLOAD_TIMEOUT_MS=600000
# MAX_PODCAST_AUDIO_MB=750
# MAX_VIDEO_TRANSCRIBE_MB=500

# HTTP request body limits
# JSON_BODY_LIMIT=1mb
# COOKIES_BODY_LIMIT=5mb
# MANUAL_CAPTURE_BODY_LIMIT=50mb

# Discord notifications
# DISCORD_WEBHOOK_URL=

# Privacy filter - comma-separated terms to hide from captures
# PRIVACY_FILTER_TERMS=

# Optional API token for mutating HTTP routes (delete/rerun/fix submit/apply)
# API_AUTH_TOKEN=change-me

# AI self-healing
# FIX_ENABLED=false
# CLAUDE_CLI_PATH=claude
# CODEX_CLI_PATH=codex
# Optional explicit args for codex invocation (append prompt automatically if no {prompt} placeholder)
# CODEX_CLI_ARGS=--print -p
# FIX_PROVIDER_TIMEOUT_MINUTES=30
